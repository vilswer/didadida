<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.didadida.video.mapper.VideoEpisodeMapper">
    
    <!-- 根据视频ID查询所有选集 -->
    <select id="selectByVideoId" resultType="com.didadida.video.entity.VideoEpisode">
        SELECT * FROM t_video_episode WHERE video_id = #{videoId} ORDER BY episode_order ASC
    </select>
    
    <!-- 根据视频ID和选集状态查询选集 -->
    <select id="selectByVideoIdAndStatus" resultType="com.didadida.video.entity.VideoEpisode">
        SELECT * FROM t_video_episode WHERE video_id = #{videoId} AND status = #{status} ORDER BY episode_order ASC
    </select>
    
</mapper>